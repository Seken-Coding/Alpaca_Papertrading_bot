# ── Alpaca credentials ─────────────────────────────────────────────────────
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# true  = paper trading (safe, no real money)
# false = live trading  (real money — use with extreme caution)
ALPACA_PAPER=true

# ── Automation settings ────────────────────────────────────────────────────
# Set AUTO_EXECUTE=true to have the bot place bracket orders automatically.
# false (default) = generate signals only; no orders placed without confirmation.
AUTO_EXECUTE=false

# How often to scan (in minutes) while the market is open.
# Default 5 = scan every 5 minutes throughout the trading day.
# The bot automatically idles when the market is closed.
SCAN_INTERVAL_MIN=5

# Maximum number of bracket orders to place in a single scan run.
# Prevents over-trading on days with many concurrent signals.
MAX_ORDERS_PER_SCAN=5

# ── Risk management ────────────────────────────────────────────────────────
# All of these are optional — the defaults shown are conservative paper-trade values.

# Position sizing
# Max fraction of equity in any single position (8%)
MAX_POSITION_PCT=0.08
# Fraction of equity risked per trade (2%)
RISK_PER_TRADE_PCT=0.02
# Stop-loss placed N x ATR below entry price
ATR_STOP_MULTIPLIER=1.8
# Minimum reward-to-risk ratio required to enter a trade
MIN_RISK_REWARD=1.2

# Portfolio limits
# Maximum concurrent open positions
MAX_POSITIONS=20
# Minimum $ buying power required to allow any new order
MIN_BUYING_POWER=500.0

# Circuit breakers — halt trading if either limit is breached
# Halt if account is down 4% from session start
MAX_DAILY_LOSS_PCT=0.04
# Halt if account is down 12% from all-time session peak
MAX_DRAWDOWN_PCT=0.12

# Signal quality filter (0-100 scale)
MIN_SCORE_THRESHOLD=45.0

# ── Position monitor ──────────────────────────────────────────────────────
# Automatically manage open positions every 60 seconds.
# true (default) = monitor enabled.
POSITION_MONITOR=true

# Percentage trail for the trailing stop upgrade.
# When a position is up 1.5x ATR from entry, the static SL is replaced with
# a trailing stop at this percentage below the high-water mark.
TRAILING_STOP_PCT=1.0

# Maximum number of calendar days to hold a position before force-closing.
# Approximates 5 trading days. Set to 0 to disable time-based exits.
MAX_HOLD_DAYS=5

# ── Market regime filter ─────────────────────────────────────────────────
# When true, blocks all new BUY entries when SPY is below its 200-day SMA
# and 5-day momentum is negative. false (default) = no regime filter.
REGIME_FILTER=false

# ── Scan time window ─────────────────────────────────────────────────────
# Only trigger strategy scans between these times (US/Eastern).
# Default: skip first 30 min (chaotic open) and last 30 min (rushed close).
# Position monitoring continues outside this window regardless.
SCAN_START_ET=10:00
SCAN_END_ET=15:30

# ── Stock universe ──────────────────────────────────────────────────────
# "static"  = scan the hardcoded 50-symbol S&P 500 sample (fast, default)
# "dynamic" = discover all tradable US stocks via Alpaca's get_assets() API,
#             then filter by price/volume in the screener (~500+ candidates)
UNIVERSE=static

# How long (seconds) to cache the dynamic asset list before re-fetching.
# Default 86400 = 24 hours.  Only relevant when UNIVERSE=dynamic.
UNIVERSE_CACHE_TTL=86400

# ── Logging ────────────────────────────────────────────────────────────────
# On a VPS use an absolute path so logs land in the same place regardless of
# the working directory.  Leave blank to use the default relative "logs/" dir.
#LOG_DIR=/opt/trading-bot/logs
