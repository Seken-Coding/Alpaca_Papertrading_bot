# ═══════════════════════════════════════════════════════════════════════════════
#                        ALPACA PAPER TRADING BOT
#                         Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your credentials:
#    cp .env.example .env
#
#  NEVER commit your .env file — it contains secrets.
#


# ─────────────────────────────────────────────────────────────────────────────
#  1. MULTI-ACCOUNT API KEYS  (multi_main.py)
# ─────────────────────────────────────────────────────────────────────────────
#  Each account maps to an entry in config/accounts.yaml.
#  Uncomment and fill in one pair per paper-trading account.
#
#  Account mapping:
#    ACCT1  ->  momentum_aggressive   (intraday scanner)
#    ACCT2  ->  cest_conservative     (CEST daily strategy)
#    ACCT3  ->  cest_aggressive       (CEST daily + pyramiding)

ACCT1_API_KEY=
ACCT1_SECRET_KEY=

ACCT2_API_KEY=
ACCT2_SECRET_KEY=

ACCT3_API_KEY=
ACCT3_SECRET_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  2. SINGLE-ACCOUNT API KEYS  (main.py / cest_main.py standalone)
# ─────────────────────────────────────────────────────────────────────────────
#  Only needed if running main.py or cest_main.py directly (not multi_main.py).
#  You can leave these blank when using multi-account mode.

#ALPACA_API_KEY=
#ALPACA_SECRET_KEY=
ALPACA_PAPER=true


# ─────────────────────────────────────────────────────────────────────────────
#  3. INTRADAY BOT  (main.py)
# ─────────────────────────────────────────────────────────────────────────────

# -- Automation --
AUTO_EXECUTE=false                  # true = place orders automatically
SCAN_INTERVAL_MIN=5                 # minutes between scans while market is open
MAX_ORDERS_PER_SCAN=5               # max bracket orders per scan cycle

# -- Position sizing --
MAX_POSITION_PCT=0.08               # max equity % in a single position (8%)
RISK_PER_TRADE_PCT=0.02             # equity % risked per trade (2%)
ATR_STOP_MULTIPLIER=1.8             # stop-loss = N x ATR below entry
MIN_RISK_REWARD=1.2                 # minimum reward:risk ratio

# -- Portfolio limits --
MAX_POSITIONS=20                    # max concurrent open positions
MIN_BUYING_POWER=500.0              # min $ buying power to allow new orders

# -- Circuit breakers --
MAX_DAILY_LOSS_PCT=0.04             # halt if down 4% from session start
MAX_DRAWDOWN_PCT=0.12               # halt if down 12% from session peak
MIN_SCORE_THRESHOLD=45.0            # signal quality filter (0-100)

# -- Position monitor --
POSITION_MONITOR=true               # auto-manage open positions every 60s
TRAILING_STOP_PCT=1.0               # trailing stop % below high-water mark
MAX_HOLD_DAYS=5                     # force-close after N calendar days (0=off)

# -- Market regime filter --
REGIME_FILTER=false                 # block BUY when SPY < 200-SMA

# -- Scan window (US/Eastern) --
SCAN_START_ET=10:00                 # skip first 30 min (chaotic open)
SCAN_END_ET=15:30                   # skip last 30 min (rushed close)

# -- Stock universe --
UNIVERSE=static                     # "static" = 50-symbol S&P sample
                                    # "dynamic" = discover via Alpaca API
UNIVERSE_CACHE_TTL=86400            # cache dynamic list for 24h (seconds)


# ─────────────────────────────────────────────────────────────────────────────
#  4. CEST BOT  (cest_main.py)
# ─────────────────────────────────────────────────────────────────────────────

#BROKER=alpaca                      # "alpaca" or "ib"
#DAILY_RUN_TIME=15:55               # daily cycle time (ET), 5 min before close


# ─────────────────────────────────────────────────────────────────────────────
#  5. LOGGING
# ─────────────────────────────────────────────────────────────────────────────
#  On a VPS, set an absolute path so logs land in a fixed location.
#  Leave blank to use the default relative "logs/" directory.

#LOG_DIR=/opt/trading-bot/logs
