# ═══════════════════════════════════════════════════════════════════════════════
#                        ALPACA PAPER TRADING BOT
#                         Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your credentials:
#    cp .env.example .env
#
#  NEVER commit your .env file — it contains secrets.
#


# ─────────────────────────────────────────────────────────────────────────────
#  1. ALPACA API KEYS (single account)
# ─────────────────────────────────────────────────────────────────────────────
#  Required for main.py and gui_main.py.

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true


# ─────────────────────────────────────────────────────────────────────────────
#  2. INTRADAY BOT  (main.py)
# ─────────────────────────────────────────────────────────────────────────────

# -- Automation --
# true = place orders automatically
AUTO_EXECUTE=false
# minutes between scans while market is open
SCAN_INTERVAL_MIN=5
# max bracket orders per scan cycle
MAX_ORDERS_PER_SCAN=5

# -- Position sizing --
# max equity % in a single position (8%)
MAX_POSITION_PCT=0.08
# equity % risked per trade (2%)
RISK_PER_TRADE_PCT=0.02
# stop-loss = N x ATR below entry
ATR_STOP_MULTIPLIER=1.8
# minimum reward:risk ratio
MIN_RISK_REWARD=1.2

# -- Portfolio limits --
# max concurrent open positions
MAX_POSITIONS=20
# min $ buying power to allow new orders
MIN_BUYING_POWER=500.0

# -- Circuit breakers --
# halt if down 4% from session start
MAX_DAILY_LOSS_PCT=0.04
# halt if down 12% from session peak
MAX_DRAWDOWN_PCT=0.12
# signal quality filter (0-100)
MIN_SCORE_THRESHOLD=45.0

# -- Position monitor --
# auto-manage open positions every 60s
POSITION_MONITOR=true
# trailing stop % below high-water mark
TRAILING_STOP_PCT=1.0
# force-close after N calendar days (0=off)
MAX_HOLD_DAYS=5

# -- Market regime filter --
# block BUY when SPY < 200-SMA
REGIME_FILTER=false

# -- Scan window (US/Eastern) --
# skip first 30 min (chaotic open)
SCAN_START_ET=10:00
# skip last 30 min (rushed close)
SCAN_END_ET=15:30

# -- Stock universe --
# "static" = 50-symbol S&P sample, "dynamic" = discover via Alpaca API
UNIVERSE=static
# cache dynamic list for 24h (seconds)
UNIVERSE_CACHE_TTL=86400


# ─────────────────────────────────────────────────────────────────────────────
#  3. LOGGING
# ─────────────────────────────────────────────────────────────────────────────
#  On a VPS, set an absolute path so logs land in a fixed location.
#  Leave blank to use the default relative "logs/" directory.

#LOG_DIR=/opt/trading-bot/logs
